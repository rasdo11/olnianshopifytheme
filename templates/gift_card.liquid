<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Gift card — {{ shop.name }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <div class="container" style="padding: 80px 0; text-align: center; max-width: 560px;">
    <div class="hero__kicker">Gift card</div>
    <h1 class="display-md" style="font-size: clamp(44px, 5vw, 72px); margin-top: 12px;">{{ gift_card.balance | money_without_trailing_zeros }}</h1>
    <div style="margin-top: 32px; padding: 32px; border-radius: 16px; background: white; border: 1px solid var(--espresso-06);">
      <div style="font-family: var(--display-font); font-size: 28px; letter-spacing: 0.1em;">{{ gift_card.code | format_code }}</div>
      <p style="margin-top: 12px; opacity: 0.72; font-size: 14px;">Redeem at checkout.</p>
    </div>
    <a href="{{ shop.url }}" class="btn btn--primary" style="margin-top: 32px;">Shop</a>
  </div>
</body>
</html>
