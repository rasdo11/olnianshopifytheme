<div class="container" style="padding: 80px 0; max-width: 480px;">
  <h1 class="display-md" style="font-size: clamp(32px, 4vw, 48px);">Activate account</h1>
  <p style="margin-top: 12px; opacity: 0.72;">Create a password to finish setting up your account.</p>

  {% form 'activate_customer_password' %}
    {{ form.errors | default_errors }}
    <div style="margin-top: 32px; display: grid; gap: 16px;">
      <input type="password" name="customer[password]" placeholder="Password" required autocomplete="new-password"
        style="padding: 12px 16px; border-radius: 12px; border: 1px solid var(--espresso-12);">
      <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required autocomplete="new-password"
        style="padding: 12px 16px; border-radius: 12px; border: 1px solid var(--espresso-12);">
      <div style="display: flex; gap: 12px;">
        <button type="submit" class="btn btn--primary" style="flex: 1;">Activate</button>
        <button type="submit" name="decline" class="btn btn--outline" style="flex: 1;">Decline</button>
      </div>
    </div>
  {% endform %}
</div>
