<section class="main-collection section--{{ section.settings.scheme | default: 'cream' }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;{% if section.settings.background != blank %} background: {{ section.settings.background }};{% endif %}">
  <div class="container">
    <div class="main-collection__header main-collection__header--{{ section.settings.header_alignment }}">
      {%- if section.settings.kicker != blank -%}
        <div class="sku-row__kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h1 class="main-collection__title">{{ collection.title }}</h1>
      {%- if section.settings.show_description and collection.description != blank -%}
        <div class="main-collection__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products_count > 0 -%}
        <div class="main-collection__toolbar" aria-label="Collection controls">
          {%- if section.settings.show_product_count -%}
            <p class="main-collection__count">
              {{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}
            </p>
          {%- endif -%}

          {%- if section.settings.enable_sorting -%}
            <form class="main-collection__sort" method="get">
              {%- for filter in collection.filters -%}
                {%- for active_value in filter.active_values -%}
                  <input type="hidden" name="{{ active_value.param_name }}" value="{{ active_value.value }}">
                {%- endfor -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value -%}<input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">{%- endif -%}
                  {%- if filter.max_value.value -%}<input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">{%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              <label for="SortBy-{{ section.id }}">Sort</label>
              <select id="SortBy-{{ section.id }}" name="sort_by" onchange="this.form.submit()">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                {%- for option in collection.sort_options -%}
                  <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name | escape }}</option>
                {%- endfor -%}
              </select>
            </form>
          {%- endif -%}
        </div>

        <div class="main-collection__grid main-collection__grid--{{ section.settings.columns_desktop }}">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product, show_swatches: section.settings.show_swatches, show_price: section.settings.show_price, cta_label: section.settings.card_cta_label %}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="main-collection__empty">
          <h2>{{ section.settings.empty_heading }}</h2>
          <p>{{ section.settings.empty_text }}</p>
          <a class="btn btn--primary" href="{{ routes.collections_url }}">{{ section.settings.empty_cta_label }}</a>
        </div>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="main-collection__pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn--outline">← Prev</a>
          {%- endif -%}
          <span class="main-collection__page-count">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn--outline">Next →</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection — main",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Collection" },
    { "type": "select", "id": "header_alignment", "label": "Header alignment", "default": "center", "options": [{"value":"center","label":"Center"},{"value":"left","label":"Left"}] },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "checkbox", "id": "show_product_count", "label": "Show product count", "default": true },
    { "type": "checkbox", "id": "enable_sorting", "label": "Enable sorting", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "select", "id": "columns_desktop", "label": "Desktop columns", "default": "3", "options": [{"value":"2","label":"2 columns"},{"value":"3","label":"3 columns"},{"value":"4","label":"4 columns"}] },
    { "type": "text", "id": "card_cta_label", "label": "Card CTA label", "default": "Shop" },
    { "type": "checkbox", "id": "show_price", "label": "Show price in card CTA", "default": true },
    { "type": "checkbox", "id": "show_swatches", "label": "Show variant swatches", "default": false },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "No products yet" },
    { "type": "textarea", "id": "empty_text", "label": "Empty text", "default": "Check back soon or browse every formula in the shop." },
    { "type": "text", "id": "empty_cta_label", "label": "Empty CTA label", "default": "Browse collections" },
    { "type": "select", "id": "scheme", "label": "Color scheme", "default": "cream", "options": [{"value":"blush","label":"Blush"},{"value":"cream","label":"Cream"},{"value":"white","label":"White"},{"value":"lavender","label":"Lavender"},{"value":"sky","label":"Blue"},{"value":"coral","label":"Coral"},{"value":"espresso","label":"Espresso"}] },
    { "type": "color", "id": "background", "label": "Custom background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "default": 96 }
  ]
}
{% endschema %}
