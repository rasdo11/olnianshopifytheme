<div class="container" style="padding: 120px 0; text-align: center; max-width: 560px;">
  <div class="hero__kicker">Coming soon</div>
  <h1 class="display-md" style="font-size: clamp(48px, 6vw, 88px); margin-top: 16px;">{{ shop.name }}</h1>
  <p style="margin-top: 24px; font-size: 18px; opacity: 0.72;">{{ shop.password_message | default: 'Pure supplements. Made the week you order.' }}</p>

  <form method="post" action="/password" style="margin-top: 40px; display: flex; gap: 12px; justify-content: center;">
    <input type="hidden" name="form_type" value="storefront_password">
    <input type="hidden" name="utf8" value="✓">
    <input type="password" name="password" placeholder="Enter password"
      style="padding: 12px 18px; border-radius: 999px; border: 1px solid var(--espresso-12); font-family: inherit;">
    <button type="submit" class="btn btn--primary">Enter</button>
  </form>

  <form method="post" action="/contact#contact_form" id="contact_form" class="contact-form" style="margin-top: 56px;">
    <input type="hidden" name="form_type" value="customer">
    <input type="hidden" name="utf8" value="✓">
    <input type="hidden" name="contact[tags]" value="prospect,newsletter">
    <div style="font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; opacity: 0.6; margin-bottom: 12px;">Be the first to know</div>
    <div style="display: flex; gap: 8px; justify-content: center;">
      <input type="email" name="contact[email]" placeholder="Email"
        style="padding: 12px 18px; border-radius: 999px; border: 1px solid var(--espresso-12); font-family: inherit; min-width: 280px;">
      <button type="submit" class="btn btn--outline">Notify me</button>
    </div>
  </form>
</div>
