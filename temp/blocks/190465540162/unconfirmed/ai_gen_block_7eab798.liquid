{% doc %}
  @prompt
    Add a custom background image upload option to the color band area of the Hero editorial section. The image should be uploadable via the theme editor and display as the background of the color band, with an option to control opacity or overlay so text remains readable. If no image is uploaded, the existing color band background should be used as a fallback.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-editorial-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-hero-editorial__color-band-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.band_color }};
    padding: {{ block.settings.band_padding }}px;
    border-radius: {{ block.settings.band_radius }}px;
    overflow: hidden;
  }

  .ai-hero-editorial__background-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: {{ block.settings.image_opacity }};
    z-index: 1;
  }

  .ai-hero-editorial__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-editorial__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-editorial__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-editorial__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-editorial__body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.body_spacing }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-editorial__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_radius }}px;
    font-size: {{ block.settings.cta_size }}px;
    font-weight: {{ block.settings.cta_weight }};
    transition: all 0.3s ease;
  }

  .ai-hero-editorial__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-editorial__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-editorial__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-editorial__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-hero-editorial__color-band-{{ ai_gen_id }} {
      padding: {{ block.settings.band_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-editorial__color-band-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-hero-editorial__background-image-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-hero-editorial__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-hero-editorial__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-editorial__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h1>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <h2 class="ai-hero-editorial__subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </h2>
      {% endif %}

      {% if block.settings.body_text != blank %}
        <div class="ai-hero-editorial__body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </div>
      {% endif %}

      {% if block.settings.cta_text != blank and block.settings.cta_link != blank %}
        <a
          href="{{ block.settings.cta_link }}"
          class="ai-hero-editorial__cta-{{ ai_gen_id }}"
        >
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

