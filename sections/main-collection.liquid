<section class="main-collection section--{{ section.settings.scheme | default: 'white' }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;{% if section.settings.background != blank %} background: {{ section.settings.background }};{% endif %}">
  <div class="container">
    <div class="main-collection__header main-collection__header--{{ section.settings.header_alignment }}">
      {%- if section.settings.kicker != blank -%}
        <div class="main-collection__kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h1 class="main-collection__title">{{ collection.title }}</h1>
      {%- if section.settings.show_description and collection.description != blank -%}
        <div class="main-collection__description">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="main-collection__toolbar">
        {%- if section.settings.show_product_count -%}
          <p class="main-collection__count">{{ paginate.items }} {{ section.settings.product_count_label }}</p>
        {%- endif -%}

        {%- if section.settings.show_sorting -%}
          <form class="main-collection__sort" method="get">
            <label for="SortBy">{{ section.settings.sort_label }}</label>
            <select id="SortBy" name="sort_by" onchange="this.form.submit()">
              {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name }}</option>
              {%- endfor -%}
            </select>
          </form>
        {%- endif -%}
      </div>

      {%- if collection.products_count > 0 -%}
        <div class="main-collection__grid main-collection__grid--{{ section.settings.desktop_columns }}">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product, show_swatches: section.settings.show_swatches, show_price: section.settings.show_price, cta_label: section.settings.card_cta_label %}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="main-collection__empty">
          <h2>{{ section.settings.empty_heading }}</h2>
          <p>{{ section.settings.empty_text }}</p>
          {%- if section.settings.empty_cta_label != blank -%}
            <a href="{{ section.settings.empty_cta_link | default: routes.all_products_collection_url }}" class="btn btn--primary">{{ section.settings.empty_cta_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="main-collection__pagination" aria-label="Collection pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn--outline">{{ section.settings.previous_label }}</a>
          {%- endif -%}
          <span class="main-collection__page-count">{{ section.settings.page_label }} {{ paginate.current_page }} {{ section.settings.page_of_label }} {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn--outline">{{ section.settings.next_label }}</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection — main",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Collection" },
    { "type": "select", "id": "header_alignment", "label": "Header alignment", "default": "center", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ]},
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "checkbox", "id": "show_product_count", "label": "Show product count", "default": true },
    { "type": "text", "id": "product_count_label", "label": "Product count label", "default": "products" },
    { "type": "header", "content": "Toolbar" },
    { "type": "checkbox", "id": "show_sorting", "label": "Show sorting", "default": true },
    { "type": "text", "id": "sort_label", "label": "Sort label", "default": "Sort" },
    { "type": "header", "content": "Product grid" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 4, "max": 48, "step": 4, "default": 24 },
    { "type": "select", "id": "desktop_columns", "label": "Desktop columns", "default": "3", "options": [
      { "value": "2", "label": "2 columns" },
      { "value": "3", "label": "3 columns" },
      { "value": "4", "label": "4 columns" }
    ]},
    { "type": "text", "id": "card_cta_label", "label": "Card CTA label", "default": "Shop" },
    { "type": "checkbox", "id": "show_price", "label": "Show price in card CTA", "default": true },
    { "type": "checkbox", "id": "show_swatches", "label": "Show variant swatches", "default": false },
    { "type": "header", "content": "Pagination" },
    { "type": "text", "id": "previous_label", "label": "Previous label", "default": "← Prev" },
    { "type": "text", "id": "next_label", "label": "Next label", "default": "Next →" },
    { "type": "text", "id": "page_label", "label": "Page label", "default": "Page" },
    { "type": "text", "id": "page_of_label", "label": "Page of label", "default": "of" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_heading", "label": "Heading", "default": "Nothing here yet." },
    { "type": "textarea", "id": "empty_text", "label": "Text", "default": "This collection is currently empty. Check back soon or explore the full OLNIAN line." },
    { "type": "text", "id": "empty_cta_label", "label": "CTA label", "default": "Shop all" },
    { "type": "url", "id": "empty_cta_link", "label": "CTA link" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "default": 96 },
    { "type": "header", "content": "Color" },
    { "type": "select", "id": "scheme", "label": "Color scheme", "default": "white", "options": [
      { "value": "blush", "label": "Blush" },
      { "value": "cream", "label": "Cream" },
      { "value": "white", "label": "White" },
      { "value": "lavender", "label": "Lavender" },
      { "value": "sky", "label": "Blue" },
      { "value": "espresso", "label": "Espresso" }
    ]},
    { "type": "color", "id": "background", "label": "Custom background" }
  ]
}
{% endschema %}
