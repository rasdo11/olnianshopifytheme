<section class="proof section--{{ section.settings.scheme | default: 'gold-tint' }}">
  <div class="container proof__container">
    <div class="sku-row__header proof__header">
      {%- if section.settings.kicker != blank -%}
        <div class="sku-row__kicker proof__kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      {%- if section.settings.headline != blank -%}
        <h2 class="sku-row__headline proof__headline">{{ section.settings.headline }}</h2>
      {%- endif -%}
      <div class="proof__social-note" aria-label="Social proof source">
        <span class="proof__social-dot"></span>
        Real notes from the OLNIAN community
      </div>
    </div>

    <div class="proof__stage" aria-label="Customer testimonials">
      <div class="proof__halo proof__halo--one" aria-hidden="true"></div>
      <div class="proof__halo proof__halo--two" aria-hidden="true"></div>
      <div class="proof__grid">
        {%- for block in section.blocks -%}
          <figure class="proof__card proof__card--{{ forloop.index }}" {{ block.shopify_attributes }}>
            <div class="proof__card-top">
              <div class="proof__profile" aria-hidden="true">
                <span class="proof__avatar">O</span>
                <span class="proof__handle">Instagram</span>
              </div>
              <span class="proof__badge">Loved</span>
            </div>
            <blockquote class="proof__quote" style="--proof-quote-size: {{ block.settings.quote_font_size | default: 24 }}px;">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
            <figcaption class="proof__attrib">{{ block.settings.attribution }}</figcaption>
            <div class="proof__actions" aria-hidden="true">
              <span>♡</span>
              <span>💬</span>
              <span>↗</span>
            </div>
          </figure>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Proof",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Testimonials" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Women in their 40s and up" },
    { "type": "header", "content": "Color band" },
    { "type": "select", "id": "scheme", "label": "Band color scheme", "default": "gold-tint", "info": "Full-bleed section background. Rotate schemes down the page.", "options": [
      { "value": "blush", "label": "Blush (cream)" },
      { "value": "cream", "label": "Warm white" },
      { "value": "white", "label": "White" },
      { "value": "flamingo", "label": "Flamingo (peach)" },
      { "value": "coral", "label": "Coral (bold)" },
      { "value": "peach", "label": "Soft peach" },
      { "value": "gold-tint", "label": "Gold tint" },
      { "value": "gold", "label": "Gold (bold)" },
      { "value": "mint-tint", "label": "Mint tint" },
      { "value": "mint", "label": "Mint (bold)" },
      { "value": "espresso", "label": "Espresso (dark)" }
    ]}
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I can tell within a week." },
        { "type": "range", "id": "quote_font_size", "label": "Quote font size", "min": 16, "max": 34, "step": 1, "unit": "px", "default": 24 },
        { "type": "text", "id": "attribution", "label": "Attribution", "default": "M., 47, Austin" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Proof",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "I can tell within a week.", "attribution": "M., 47, Austin" } },
        { "type": "testimonial", "settings": { "quote": "The only supplement I've stayed on.", "attribution": "R., 52, Portland" } },
        { "type": "testimonial", "settings": { "quote": "Sleep and strength, same bottle.", "attribution": "L., 44, Brooklyn" } }
      ]
    }
  ]
}
{% endschema %}
