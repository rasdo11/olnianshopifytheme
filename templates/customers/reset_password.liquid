<div class="container" style="padding: 80px 0; max-width: 480px;">
  <h1 class="display-md" style="font-size: clamp(32px, 4vw, 48px);">Reset password</h1>
  {% form 'reset_customer_password' %}
    {{ form.errors | default_errors }}
    <div style="margin-top: 32px; display: grid; gap: 16px;">
      <input type="password" name="customer[password]" placeholder="New password" required autocomplete="new-password"
        style="padding: 12px 16px; border-radius: 12px; border: 1px solid var(--espresso-12);">
      <input type="password" name="customer[password_confirmation]" placeholder="Confirm new password" required autocomplete="new-password"
        style="padding: 12px 16px; border-radius: 12px; border: 1px solid var(--espresso-12);">
      <button type="submit" class="btn btn--primary">Reset password</button>
    </div>
  {% endform %}
</div>
