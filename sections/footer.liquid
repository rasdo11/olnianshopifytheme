<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__brand-col">
        <div class="site-footer__brand">{{ settings.brand_name | default: shop.name }}</div>
        <p class="site-footer__tagline">{{ settings.brand_tagline }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          {%- assign footer_heading = block.settings.heading | default: 'Shop' -%}
          <div class="site-footer__menu-col" {{ block.shopify_attributes }}>
            <div class="site-footer__heading">{{ footer_heading }}</div>
            <ul class="site-footer__list">
              {%- assign has_custom_links = false -%}
              {%- if block.settings.link_label_1 != blank or block.settings.link_url_1 != blank or block.settings.link_label_2 != blank or block.settings.link_url_2 != blank or block.settings.link_label_3 != blank or block.settings.link_url_3 != blank or block.settings.link_label_4 != blank or block.settings.link_url_4 != blank or block.settings.link_label_5 != blank or block.settings.link_url_5 != blank or block.settings.link_label_6 != blank or block.settings.link_url_6 != blank -%}
                {%- assign has_custom_links = true -%}
              {%- endif -%}

              {%- if has_custom_links -%}
                {%- if block.settings.link_label_1 != blank or block.settings.link_url_1 != blank -%}<li><a href="{{ block.settings.link_url_1 | default: '#' }}">{{ block.settings.link_label_1 | default: block.settings.link_url_1 }}</a></li>{%- endif -%}
                {%- if block.settings.link_label_2 != blank or block.settings.link_url_2 != blank -%}<li><a href="{{ block.settings.link_url_2 | default: '#' }}">{{ block.settings.link_label_2 | default: block.settings.link_url_2 }}</a></li>{%- endif -%}
                {%- if block.settings.link_label_3 != blank or block.settings.link_url_3 != blank -%}<li><a href="{{ block.settings.link_url_3 | default: '#' }}">{{ block.settings.link_label_3 | default: block.settings.link_url_3 }}</a></li>{%- endif -%}
                {%- if block.settings.link_label_4 != blank or block.settings.link_url_4 != blank -%}<li><a href="{{ block.settings.link_url_4 | default: '#' }}">{{ block.settings.link_label_4 | default: block.settings.link_url_4 }}</a></li>{%- endif -%}
                {%- if block.settings.link_label_5 != blank or block.settings.link_url_5 != blank -%}<li><a href="{{ block.settings.link_url_5 | default: '#' }}">{{ block.settings.link_label_5 | default: block.settings.link_url_5 }}</a></li>{%- endif -%}
                {%- if block.settings.link_label_6 != blank or block.settings.link_url_6 != blank -%}<li><a href="{{ block.settings.link_url_6 | default: '#' }}">{{ block.settings.link_label_6 | default: block.settings.link_url_6 }}</a></li>{%- endif -%}
              {%- elsif block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                {%- case footer_heading | handleize -%}
                  {%- when 'shop' -%}
                    <li><a href="/collections/all">Shop the Line</a></li>
                    <li><a href="/products/creatine">Creatine</a></li>
                    <li><a href="/products/magnesium-complex">Magnesium</a></li>
                    <li><a href="/products/colostrum">Colostrum</a></li>
                  {%- when 'company' -%}
                    <li><a href="/pages/about-us">About OLNIAN</a></li>
                    <li><a href="/pages/contact">Contact</a></li>
                  {%- when 'help' -%}
                    <li><a href="/pages/contact">Contact</a></li>
                    <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
                    <li><a href="/policies/terms-of-service">Terms of Service</a></li>
                    <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
                    <li><a href="/policies/refund-policy">Refund Policy</a></li>
                {%- endcase -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="site-footer__signup-col">
        <div class="site-footer__signup-heading">{{ section.settings.signup_heading | default: 'Join the list' }}</div>
        {%- if section.settings.signup_text != blank -%}
          <p class="site-footer__tagline" style="margin-bottom: 12px;">{{ section.settings.signup_text }}</p>
        {%- endif -%}
        {%- form 'customer', class: 'site-footer__signup-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="FooterEmail">Email</label>
          <input
            type="email"
            name="contact[email]"
            id="FooterEmail"
            class="site-footer__signup-input"
            value="{{ form.email }}"
            placeholder="{{ section.settings.signup_placeholder | default: 'Email' }}"
            autocomplete="email"
            required>
          <button type="submit" class="site-footer__signup-btn" aria-label="Subscribe">&rarr;</button>
          {%- if form.posted_successfully? -%}
            <p class="newsletter__success" role="status" style="flex-basis:100%; margin-top:8px;">Thanks, you are on the list.</p>
          {%- elsif form.errors -%}
            <p class="site-footer__tagline" role="alert" style="flex-basis:100%; margin-top:8px;">{{ form.errors | default_errors }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    <div class="site-footer__bottom">
      {%- if section.settings.contact_phone != blank or section.settings.contact_email != blank -%}
        <div class="site-footer__contact" aria-label="Contact OLNIAN">
          {%- if section.settings.contact_phone != blank -%}
            <a href="tel:{{ section.settings.contact_phone | remove: ' ' }}">{{ section.settings.contact_phone }}</a>
          {%- endif -%}
          {%- if section.settings.contact_email != blank -%}
            <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- assign has_custom_legal_links = false -%}
      {%- if section.settings.legal_label_1 != blank or section.settings.legal_url_1 != blank or section.settings.legal_label_2 != blank or section.settings.legal_url_2 != blank or section.settings.legal_label_3 != blank or section.settings.legal_url_3 != blank or section.settings.legal_label_4 != blank or section.settings.legal_url_4 != blank or section.settings.legal_label_5 != blank or section.settings.legal_url_5 != blank or section.settings.legal_label_6 != blank or section.settings.legal_url_6 != blank -%}
        {%- assign has_custom_legal_links = true -%}
      {%- endif -%}

      {%- if has_custom_legal_links -%}
        <div class="site-footer__legal">
          {%- if section.settings.legal_label_1 != blank or section.settings.legal_url_1 != blank -%}<a href="{{ section.settings.legal_url_1 | default: '#' }}">{{ section.settings.legal_label_1 | default: section.settings.legal_url_1 }}</a>{%- endif -%}
          {%- if section.settings.legal_label_2 != blank or section.settings.legal_url_2 != blank -%}<a href="{{ section.settings.legal_url_2 | default: '#' }}">{{ section.settings.legal_label_2 | default: section.settings.legal_url_2 }}</a>{%- endif -%}
          {%- if section.settings.legal_label_3 != blank or section.settings.legal_url_3 != blank -%}<a href="{{ section.settings.legal_url_3 | default: '#' }}">{{ section.settings.legal_label_3 | default: section.settings.legal_url_3 }}</a>{%- endif -%}
          {%- if section.settings.legal_label_4 != blank or section.settings.legal_url_4 != blank -%}<a href="{{ section.settings.legal_url_4 | default: '#' }}">{{ section.settings.legal_label_4 | default: section.settings.legal_url_4 }}</a>{%- endif -%}
          {%- if section.settings.legal_label_5 != blank or section.settings.legal_url_5 != blank -%}<a href="{{ section.settings.legal_url_5 | default: '#' }}">{{ section.settings.legal_label_5 | default: section.settings.legal_url_5 }}</a>{%- endif -%}
          {%- if section.settings.legal_label_6 != blank or section.settings.legal_url_6 != blank -%}<a href="{{ section.settings.legal_url_6 | default: '#' }}">{{ section.settings.legal_label_6 | default: section.settings.legal_url_6 }}</a>{%- endif -%}
        </div>
      {%- elsif section.settings.legal_menu != blank and section.settings.legal_menu.links.size > 0 -%}
        <div class="site-footer__legal">
          {%- for link in section.settings.legal_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="site-footer__legal">
          <a href="/policies/privacy-policy">Privacy Policy</a>
          <a href="/policies/terms-of-service">Terms of Service</a>
          <a href="/policies/shipping-policy">Shipping Policy</a>
          <a href="/policies/refund-policy">Refund Policy</a>
        </div>
      {%- endif -%}

      <div class="site-footer__copy">© {{ 'now' | date: "%Y" }} {{ settings.brand_name | default: shop.name }}. All rights reserved.</div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Email signup" },
    { "type": "text", "id": "signup_heading", "label": "Signup heading", "default": "Join the list" },
    { "type": "text", "id": "signup_text", "label": "Signup text (optional)", "default": "Batch drops & restock alerts." },
    { "type": "text", "id": "signup_placeholder", "label": "Input placeholder", "default": "Email" },
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "contact_phone", "label": "Phone", "default": "+1 206-669-0016" },
    { "type": "text", "id": "contact_email", "label": "Email", "default": "hello@olnian.com" },
    { "type": "header", "content": "Legal" },
    { "type": "link_list", "id": "legal_menu", "label": "Legal links menu", "info": "Optional. If custom legal links below are filled in, those links show instead of this menu." },
    { "type": "text", "id": "legal_label_1", "label": "Legal link 1 label" },
    { "type": "url", "id": "legal_url_1", "label": "Legal link 1 URL" },
    { "type": "text", "id": "legal_label_2", "label": "Legal link 2 label" },
    { "type": "url", "id": "legal_url_2", "label": "Legal link 2 URL" },
    { "type": "text", "id": "legal_label_3", "label": "Legal link 3 label" },
    { "type": "url", "id": "legal_url_3", "label": "Legal link 3 URL" },
    { "type": "text", "id": "legal_label_4", "label": "Legal link 4 label" },
    { "type": "url", "id": "legal_url_4", "label": "Legal link 4 URL" },
    { "type": "text", "id": "legal_label_5", "label": "Legal link 5 label" },
    { "type": "url", "id": "legal_url_5", "label": "Legal link 5 URL" },
    { "type": "text", "id": "legal_label_6", "label": "Legal link 6 label" },
    { "type": "url", "id": "legal_url_6", "label": "Legal link 6 URL" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "info": "Optional. If you fill in the custom links below, those links show instead of this menu." },
        { "type": "header", "content": "Custom links" },
        { "type": "text", "id": "link_label_1", "label": "Link 1 label" },
        { "type": "url", "id": "link_url_1", "label": "Link 1 URL" },
        { "type": "text", "id": "link_label_2", "label": "Link 2 label" },
        { "type": "url", "id": "link_url_2", "label": "Link 2 URL" },
        { "type": "text", "id": "link_label_3", "label": "Link 3 label" },
        { "type": "url", "id": "link_url_3", "label": "Link 3 URL" },
        { "type": "text", "id": "link_label_4", "label": "Link 4 label" },
        { "type": "url", "id": "link_url_4", "label": "Link 4 URL" },
        { "type": "text", "id": "link_label_5", "label": "Link 5 label" },
        { "type": "url", "id": "link_url_5", "label": "Link 5 URL" },
        { "type": "text", "id": "link_label_6", "label": "Link 6 label" },
        { "type": "url", "id": "link_url_6", "label": "Link 6 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Company" } },
        { "type": "menu", "settings": { "heading": "Help" } }
      ]
    }
  ]
}
{% endschema %}
