[
  {
    "name": "theme_info",
    "theme_name": "Olnian",
    "theme_version": "1.0.0",
    "theme_author": "Olnian",
    "theme_documentation_url": "https://olnian.com",
    "theme_support_url": "https://olnian.com"
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_background",      "label": "Background",          "default": "#FFF8F0" },
      { "type": "color", "id": "color_text",             "label": "Body text",           "default": "#2E1206" },
      { "type": "color", "id": "color_accent_primary",   "label": "Coral (primary)",     "default": "#FF5A2C" },
      { "type": "color", "id": "color_accent_secondary", "label": "Flamingo",            "default": "#FEB3A0" },
      { "type": "color", "id": "color_accent_gold",      "label": "Gold",                "default": "#E8A13C" },
      { "type": "color", "id": "color_accent_mint",      "label": "Mint",                "default": "#3ECFB2" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "header", "content": "Heading font" },
      {
        "type": "select",
        "id": "display_font",
        "label": "Heading font family",
        "options": [
          { "value": "Nunito Sans",         "label": "Nunito Sans (sans)" },
          { "value": "DM Sans",             "label": "DM Sans (sans)" },
          { "value": "Space Grotesk",       "label": "Space Grotesk (sans)" },
          { "value": "Plus Jakarta Sans",   "label": "Plus Jakarta Sans (sans)" },
          { "value": "Belleza",             "label": "Belleza (serif)" },
          { "value": "Cormorant Garamond",  "label": "Cormorant Garamond (serif)" },
          { "value": "Instrument Serif",    "label": "Instrument Serif (serif)" },
          { "value": "Playfair Display",    "label": "Playfair Display (serif)" },
          { "value": "Fraunces",            "label": "Fraunces (serif)" },
          { "value": "Newsreader",          "label": "Newsreader (serif)" }
        ],
        "default": "Nunito Sans"
      },
      {
        "type": "select",
        "id": "display_font_weight",
        "label": "Heading weight",
        "info": "Belleza & Instrument Serif are one weight only (400) — heavier weights fall back to 400 for those.",
        "options": [
          { "value": "300", "label": "Light (300)" },
          { "value": "400", "label": "Regular (400)" },
          { "value": "500", "label": "Medium (500)" },
          { "value": "600", "label": "Semi-bold (600)" },
          { "value": "700", "label": "Bold (700)" },
          { "value": "800", "label": "Extra-bold (800)" },
          { "value": "900", "label": "Black (900)" }
        ],
        "default": "800"
      },
      { "type": "header", "content": "Body font" },
      {
        "type": "select",
        "id": "body_font",
        "label": "Body font family",
        "options": [
          { "value": "Nunito Sans",       "label": "Nunito Sans" },
          { "value": "DM Sans",           "label": "DM Sans" },
          { "value": "Space Grotesk",     "label": "Space Grotesk" },
          { "value": "Plus Jakarta Sans", "label": "Plus Jakarta Sans" },
          { "value": "Jost",              "label": "Jost" },
          { "value": "Epilogue",          "label": "Epilogue" }
        ],
        "default": "Nunito Sans"
      },
      {
        "type": "select",
        "id": "body_font_weight",
        "label": "Body weight",
        "options": [
          { "value": "300", "label": "Light (300)" },
          { "value": "400", "label": "Regular (400)" },
          { "value": "500", "label": "Medium (500)" },
          { "value": "600", "label": "Semi-bold (600)" },
          { "value": "700", "label": "Bold (700)" }
        ],
        "default": "400"
      }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      { "type": "text",     "id": "brand_name",        "label": "Brand name",    "default": "OLNIAN" },
      { "type": "textarea", "id": "brand_tagline",     "label": "Tagline",       "default": "Brain • Body • Balance." },
      { "type": "image_picker", "id": "favicon",       "label": "Favicon" },
      {
        "type": "range",
        "id": "brand_logo_padding_left",
        "label": "Brand name — left padding (px)",
        "min": 0,
        "max": 60,
        "step": 1,
        "default": 15
      }
    ]
  },
  {
    "name": "Shipping badge",
    "settings": [
      { "type": "checkbox", "id": "show_ship_badge",  "label": "Show shipping badge",  "default": true },
      { "type": "text",     "id": "ship_badge_text",  "label": "Badge text",           "default": "Ships in 2\u20134 weeks" }
    ]
  },
  {
    "name": "Design controls",
    "settings": [
      { "type": "color", "id": "color_lavender", "label": "Lavender", "default": "#DCC7FF" },
      { "type": "color", "id": "color_sky", "label": "Editorial blue", "default": "#0066A6" },
      { "type": "range", "id": "button_radius", "label": "Button radius (px)", "min": 0, "max": 40, "step": 1, "default": 28 },
      { "type": "range", "id": "card_radius", "label": "Card radius (px)", "min": 0, "max": 40, "step": 1, "default": 24 },
      { "type": "select", "id": "product_card_ratio", "label": "Product card image ratio", "default": "portrait", "options": [
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" }
      ]}
    ]
  }


  ,
  {
    "name": "Sitewide motion and popup",
    "settings": [
      { "type": "checkbox", "id": "enable_scroll_fade", "label": "Scroll-triggered fade-in animations (all devices)", "default": true },
      { "type": "checkbox", "id": "enable_scroll_parallax", "label": "Parallax on text and imagery (desktop and mobile)", "default": true },
      { "type": "range", "id": "parallax_strength", "label": "Parallax strength for desktop and mobile", "min": 0, "max": 40, "step": 5, "default": 15 },
      { "type": "checkbox", "id": "enable_email_popup", "label": "Enable 10% email popup", "default": true },
      { "type": "range", "id": "email_popup_delay", "label": "Popup delay", "min": 1, "max": 15, "step": 1, "unit": "s", "default": 5 }
    ]
  }

]
