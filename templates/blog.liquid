<div class="container" style="padding: 80px 0;">
  <h1 class="display-md" style="font-size: clamp(40px, 5vw, 64px);">{{ blog.title }}</h1>

  {%- paginate blog.articles by 12 -%}
    <div style="margin-top: 48px; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px;">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="sku-card" style="padding: 0; overflow: hidden;">
          {%- if article.image -%}
            <div style="aspect-ratio: 4 / 3; overflow: hidden; border-radius: 20px 20px 0 0;">
              {{ article.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: article.title }}
            </div>
          {%- endif -%}
          <div style="padding: 24px;">
            <div style="font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.6;">
              {{ article.published_at | date: '%b %d, %Y' }}
            </div>
            <h2 class="serif" style="font-size: 24px; margin-top: 8px;">{{ article.title }}</h2>
            {%- if article.excerpt != blank -%}
              <p style="margin-top: 10px; opacity: 0.72; font-size: 15px;">{{ article.excerpt | strip_html | truncatewords: 24 }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav style="margin-top: 48px; display: flex; gap: 12px; justify-content: center;">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="btn btn--outline">← Prev</a>{%- endif -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="btn btn--outline">Next →</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>
