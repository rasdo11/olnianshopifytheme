<section class="hero page-enter section--{{ section.settings.scheme | default: 'blush' }}" style="
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  {% if section.settings.background != blank %}background-color: {{ section.settings.background }};{% endif %}
  {% if section.settings.background_image != blank %}
    background-image: url({{ section.settings.background_image | image_url: width: 2400 }});
    background-size: {{ section.settings.background_image_size | default: 'cover' }};
    background-position: {{ section.settings.background_image_position | default: 'center center' }};
    background-repeat: no-repeat;
  {% endif %}
  --hero-highlight-color: {{ section.settings.highlight_color | default: '#F3A08D' }};
  --hero-headline-line-height: {{ section.settings.headline_line_height | default: 94 | divided_by: 100.0 }};
  --hero-mobile-headline-line-height: {{ section.settings.mobile_headline_line_height | default: 90 | divided_by: 100.0 }};
  --hero-mobile-side-padding: {{ section.settings.mobile_side_padding | default: 20 }}px;
">
  <div class="container hero__grid hero__grid--image-{{ section.settings.image_position | default: 'left' }}">
    <div>
      {%- if section.settings.kicker != blank -%}
        <div class="hero__kicker" style="
          font-size: {{ section.settings.kicker_size }}px;
          letter-spacing: {{ section.settings.kicker_kerning | divided_by: 100.0 }}em;
        ">{{ section.settings.kicker }}</div>
      {%- endif -%}

      {%- if section.settings.badge != blank -%}
        <div class="hero__badge">{{ section.settings.badge }}</div>
      {%- endif -%}

      {%- assign hero_headline = section.settings.headline | escape | newline_to_br -%}
      {%- if section.settings.highlight_1 != blank -%}
        {%- assign highlight_1_text = section.settings.highlight_1 | escape -%}
        {%- capture highlight_1_markup -%}<mark class="hero__highlight">{{ highlight_1_text }}</mark>{%- endcapture -%}
        {%- assign hero_headline = hero_headline | replace: highlight_1_text, highlight_1_markup -%}
      {%- endif -%}
      {%- if section.settings.highlight_2 != blank -%}
        {%- assign highlight_2_text = section.settings.highlight_2 | escape -%}
        {%- capture highlight_2_markup -%}<mark class="hero__highlight">{{ highlight_2_text }}</mark>{%- endcapture -%}
        {%- assign hero_headline = hero_headline | replace: highlight_2_text, highlight_2_markup -%}
      {%- endif -%}

      <h1 class="hero__headline" style="
        font-size: {{ section.settings.headline_size }}px;
        letter-spacing: {{ section.settings.headline_kerning | divided_by: 100.0 }}em;
      ">{{ hero_headline }}</h1>

      {%- if section.settings.subheadline != blank -%}
        <p class="hero__sub" style="font-size: {{ section.settings.subheadline_size }}px;">{{ section.settings.subheadline }}</p>
      {%- endif -%}

      {%- if section.settings.show_trust_row -%}
        <div class="hero__trust">
          {%- if section.settings.trust_1 != blank -%}<span>{{ section.settings.trust_1 }}</span>{%- endif -%}
          {%- if section.settings.trust_2 != blank -%}<span>{{ section.settings.trust_2 }}</span>{%- endif -%}
          {%- if section.settings.trust_3 != blank -%}<span>{{ section.settings.trust_3 }}</span>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="hero__ctas" style="margin-top: {{ section.settings.cta_margin_top }}px;">
        {%- if section.settings.primary_cta_label != blank -%}
          <a href="{{ section.settings.primary_cta_link | default: routes.collections_url | append: '/all' }}" class="btn btn--primary">
            {{ section.settings.primary_cta_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_label != blank -%}
          {%- if section.settings.secondary_opens_quiz -%}
            <button type="button" class="btn btn--outline" data-quiz-open aria-haspopup="dialog">
              {{ section.settings.secondary_cta_label }}
            </button>
          {%- else -%}
            <a href="{{ section.settings.secondary_cta_link }}" class="btn btn--outline">
              {{ section.settings.secondary_cta_label }}
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <div class="hero__image" style="--hero-media-ratio: {{ section.settings.media_ratio | default: '1 / 1.1' }}; --hero-media-fit: {{ section.settings.media_fit | default: 'cover' }};">
      {%- assign hero_video_poster = blank -%}
      {%- if section.settings.image != blank -%}
        {%- assign hero_video_poster = section.settings.image | image_url: width: 1800 -%}
      {%- endif -%}
      {%- if section.settings.hero_video != blank -%}
        {{ section.settings.hero_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, image_size: '1800x', poster: hero_video_poster, class: 'hero__video' }}
        <button type="button" class="hero__video-play" aria-label="Play hero video" data-hero-video-play>
          <span aria-hidden="true">▶</span>
        </button>
      {%- elsif section.settings.hero_video_url != blank -%}
        <video class="hero__video" src="{{ section.settings.hero_video_url | escape }}"{% if hero_video_poster != blank %} poster="{{ hero_video_poster }}"{% endif %} autoplay loop muted playsinline></video>
        <button type="button" class="hero__video-play" aria-label="Play hero video" data-hero-video-play>
          <span aria-hidden="true">▶</span>
        </button>
      {%- elsif section.settings.image != blank -%}
        {%- assign hero_image_alt = section.settings.image.alt | default: section.settings.headline -%}
        {{ section.settings.image
          | image_url: width: 1800
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '375, 550, 750, 900, 1100, 1400, 1800',
            sizes: '(max-width: 600px) 100vw, (max-width: 900px) 92vw, 50vw',
            alt: hero_image_alt
        }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero — editorial",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Pure Supplements for Her" },
    { "type": "text", "id": "badge", "label": "Badge pill (optional)", "default": "New batch: ships in 2\u20134 weeks" },
    { "type": "textarea", "id": "headline", "label": "Headline", "default": "Clean Creatine.\nClear Thinking." },
    { "type": "textarea", "id": "subheadline", "label": "Sub-headline", "default": "Three to five grams of pure, micronized creatine monohydrate per serving. Studied specifically in women after 40." },
    { "type": "header", "content": "Headline highlights" },
    { "type": "text", "id": "highlight_1", "label": "Highlight phrase 1", "default": "beauty" },
    { "type": "text", "id": "highlight_2", "label": "Highlight phrase 2", "default": "science" },
    { "type": "color", "id": "highlight_color", "label": "Highlighter color", "default": "#F3A08D" },
    { "type": "header", "content": "Hero media video or image" },
    { "type": "image_picker", "id": "image", "label": "Hero image fallback" },
    { "type": "video", "id": "hero_video", "label": "Hero video picker", "info": "Optional Shopify-hosted video. If set, it replaces the hero image and pauses when tapped." },
    { "type": "text", "id": "hero_video_url", "label": "Hero video MP4 URL", "default": "https://cdn.shopify.com/videos/c/o/v/db1af56a022b45339ec21f7c8facc30b.mp4", "info": "Paste a hosted MP4 URL here if the video picker is not showing your file." },
    { "type": "select", "id": "media_ratio", "label": "Hero image ratio", "default": "1 / 1.1", "options": [
      { "value": "auto", "label": "Natural" },
      { "value": "1 / 1", "label": "Square" },
      { "value": "1 / 1.1", "label": "Soft portrait" },
      { "value": "4 / 5", "label": "Portrait" },
      { "value": "9 / 16", "label": "Tall portrait" },
      { "value": "3 / 2", "label": "Landscape" }
    ]},
    { "type": "select", "id": "media_fit", "label": "Hero image fit", "default": "cover", "options": [
      { "value": "cover", "label": "Fill/crop" },
      { "value": "contain", "label": "Show full image" }
    ]},
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ]},
    { "type": "header", "content": "Trust row" },
    { "type": "checkbox", "id": "show_trust_row", "label": "Show trust row", "default": true },
    { "type": "text", "id": "trust_1", "label": "Trust item 1", "default": "Third-party tested" },
    { "type": "text", "id": "trust_2", "label": "Trust item 2", "default": "No fillers" },
    { "type": "text", "id": "trust_3", "label": "Trust item 3", "default": "Made fresh to order" },
    { "type": "header", "content": "CTAs" },
    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label", "default": "Shop" },
    { "type": "url", "id": "primary_cta_link", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label", "default": "Is creatine for me?" },
    { "type": "checkbox", "id": "secondary_opens_quiz", "label": "Secondary CTA opens quiz", "default": true },
    { "type": "url", "id": "secondary_cta_link", "label": "Secondary CTA link (if not quiz)" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "headline_size", "label": "Headline size (px)", "min": 28, "max": 100, "step": 2, "default": 64 },
    { "type": "range", "id": "headline_line_height", "label": "Headline line spacing desktop (% line-height)", "min": 80, "max": 120, "step": 1, "default": 94 },
    { "type": "range", "id": "mobile_headline_line_height", "label": "Headline line spacing mobile (% line-height)", "min": 80, "max": 120, "step": 1, "default": 90 },
    { "type": "range", "id": "mobile_side_padding", "label": "Mobile side padding (px)", "min": 12, "max": 40, "step": 2, "default": 20 },
    { "type": "range", "id": "headline_kerning", "label": "Headline letter-spacing (em × 100)", "min": -5, "max": 10, "step": 1, "default": 0, "info": "Divide by 100 for em value. 0 = natural font spacing" },
    { "type": "range", "id": "subheadline_size", "label": "Sub-headline size (px)", "min": 13, "max": 24, "step": 1, "default": 17 },
    { "type": "range", "id": "kicker_size", "label": "Kicker size (px)", "min": 9, "max": 16, "step": 1, "default": 11 },
    { "type": "range", "id": "kicker_kerning", "label": "Kicker letter-spacing (em × 100)", "min": 0, "max": 40, "step": 1, "default": 22 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 160, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 160, "step": 8, "default": 80 },
    { "type": "range", "id": "cta_margin_top", "label": "CTA top spacing (px)", "min": 8, "max": 64, "step": 4, "default": 32 },
    { "type": "header", "content": "Color band" },
    { "type": "image_picker", "id": "background_image", "label": "Color band background image" },
    { "type": "select", "id": "background_image_size", "label": "Background image size", "default": "cover", "options": [
      { "value": "cover", "label": "Cover band" },
      { "value": "contain", "label": "Show full image" }
    ]},
    { "type": "select", "id": "background_image_position", "label": "Background image position", "default": "center center", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ]},
    { "type": "select", "id": "scheme", "label": "Band color scheme", "default": "blush", "info": "Full-bleed section background. Rotate schemes down the page.", "options": [
      { "value": "blush", "label": "Blush (cream)" },
      { "value": "cream", "label": "Warm white" },
      { "value": "white", "label": "White" },
      { "value": "flamingo", "label": "Flamingo (peach)" },
      { "value": "coral", "label": "Coral (bold)" },
      { "value": "peach", "label": "Soft peach" },
      { "value": "gold-tint", "label": "Gold tint" },
      { "value": "gold", "label": "Gold (bold)" },
      { "value": "mint-tint", "label": "Mint tint" },
      { "value": "mint", "label": "Mint (bold)" },
      { "value": "espresso", "label": "Espresso (dark)" }
    ]},
    { "type": "color", "id": "background", "label": "Custom background (overrides scheme)" }
  ],
  "presets": [
    { "name": "Hero — editorial", "category": "Image" }
  ]
}
{% endschema %}