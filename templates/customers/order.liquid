<div class="container" style="padding: 80px 0; max-width: 800px;">
  <h1 class="display-md" style="font-size: clamp(32px, 4vw, 48px);">Order {{ order.name }}</h1>
  <div style="opacity: 0.6; margin-top: 8px; font-size: 14px;">Placed {{ order.created_at | date: '%B %d, %Y' }}</div>

  <div style="margin-top: 40px; display: grid; gap: 16px;">
    {%- for line_item in order.line_items -%}
      <div style="display: grid; grid-template-columns: 96px 1fr auto; gap: 20px; padding: 20px; background: white; border-radius: 12px; border: 1px solid var(--espresso-06);">
        {%- if line_item.image -%}
          <img src="{{ line_item.image | image_url: width: 192 }}" alt="{{ line_item.title | escape }}" style="width: 96px; aspect-ratio: 1; object-fit: cover; border-radius: 8px;">
        {%- else -%}
          <div></div>
        {%- endif -%}
        <div>
          <div class="serif" style="font-size: 18px;">{{ line_item.product.title }}</div>
          {%- if line_item.variant.title != 'Default Title' -%}
            <div style="opacity: 0.6; font-size: 13px;">{{ line_item.variant.title }}</div>
          {%- endif -%}
          {%- if line_item.selling_plan_allocation -%}
            <div style="color: var(--tangerine); font-size: 13px; margin-top: 4px;">{{ line_item.selling_plan_allocation.selling_plan.name }}</div>
          {%- endif -%}
          <div style="margin-top: 8px; font-size: 14px;">Qty {{ line_item.quantity }}</div>
        </div>
        <div style="font-family: var(--display-font); font-size: 18px;">{{ line_item.final_line_price | money }}</div>
      </div>
    {%- endfor -%}
  </div>

  <div style="margin-top: 40px; padding: 24px; background: white; border-radius: 12px; border: 1px solid var(--espresso-06);">
    <div style="display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px;"><span>Subtotal</span><span>{{ order.subtotal_price | money }}</span></div>
    <div style="display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px;"><span>Shipping</span><span>{{ order.shipping_price | money }}</span></div>
    <div style="display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px;"><span>Tax</span><span>{{ order.tax_price | money }}</span></div>
    <div style="display: flex; justify-content: space-between; padding: 12px 0 0; font-family: var(--display-font); font-size: 22px; border-top: 1px solid var(--espresso-06); margin-top: 8px;">
      <span>Total</span><span>{{ order.total_price | money }}</span>
    </div>
  </div>

  <a href="{{ routes.account_url }}" style="display: inline-block; margin-top: 32px; text-decoration: underline;">← Back to account</a>
</div>
